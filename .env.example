# ─── Copie este arquivo para .env para rodar localmente ───────────────────────
# No Railway, configure estas variáveis em: Project → Variables

# Banco de dados — gerado automaticamente pelo plugin Postgres do Railway
DATABASE_URL=postgresql://postgres:PASSWORD@HOST.railway.internal:5432/railway

# CORS — domínio do frontend (sem barra no final)
ALLOWED_ORIGINS=https://mailing.gutowskicobrancagarantida.com.br

# JWT — string aleatória segura (mínimo 32 chars)
JWT_SECRET=troque_por_uma_string_muito_segura_aqui_32chars

# Porta (Railway define automaticamente)
PORT=3000

# Ambiente
NODE_ENV=production
